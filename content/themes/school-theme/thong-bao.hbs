{{!< default}}
<style>
/* ===== TRANG THÔNG BÁO ===== */
.tb-page {
    max-width: 900px;
    margin: 48px auto;
    padding: 0 24px;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}

.tb-page-title {
    font-size: 28px;
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.tb-page-title::after {
    content: '';
    flex: 1;
    height: 3px;
    background: linear-gradient(90deg, #2a5298, transparent);
    border-radius: 2px;
    margin-left: 12px;
}

.tb-subtitle {
    color: #718096;
    font-size: 14px;
    margin-bottom: 32px;
}

/* ===== CARD THÔNG BÁO ===== */
.tb-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.tb-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    padding: 22px 26px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    border-left: 4px solid #2a5298;
    transition: transform 0.18s, box-shadow 0.18s;
    text-decoration: none;
    color: inherit;
}

.tb-card:hover {
    transform: translateX(4px);
    box-shadow: 0 6px 24px rgba(42,82,152,0.13);
    border-left-color: #e53e3e;
}

.tb-card-icon {
    font-size: 28px;
    flex-shrink: 0;
    margin-top: 2px;
}

.tb-card-body {
    flex: 1;
    min-width: 0;
}

.tb-card-title {
    font-size: 16px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 6px;
    line-height: 1.4;
    text-decoration: none;
}

.tb-card:hover .tb-card-title {
    color: #2a5298;
}

.tb-card-excerpt {
    font-size: 13.5px;
    color: #718096;
    line-height: 1.6;
    margin: 0 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.tb-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
}

.tb-badge {
    background: #ebf4ff;
    color: #2a5298;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
}

.tb-date {
    font-size: 12px;
    color: #a0aec0;
    display: flex;
    align-items: center;
    gap: 4px;
}

.tb-readmore {
    font-size: 12px;
    color: #2a5298;
    font-weight: 600;
    margin-left: auto;
    white-space: nowrap;
}

/* ===== EMPTY STATE ===== */
.tb-empty {
    text-align: center;
    padding: 60px 20px;
    color: #a0aec0;
    font-size: 15px;
}

.tb-empty-icon {
    font-size: 48px;
    display: block;
    margin-bottom: 12px;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 600px) {
    .tb-card {
        padding: 16px 18px;
        gap: 14px;
    }
    .tb-card-icon { font-size: 22px; }
    .tb-card-title { font-size: 15px; }
    .tb-readmore { display: none; }
}
</style>


<div class="tb-page">
    <h1 class="tb-page-title">📢 Thông báo</h1>
    <p class="tb-subtitle">Cập nhật các thông báo mới nhất từ nhà trường</p>

    <div class="tb-list">
        {{#get "posts" filter="tag:thong-bao" limit="10"}}
            {{#foreach posts}}
            <a class="tb-card" href="{{url}}">
                <div class="tb-card-icon">📌</div>
                <div class="tb-card-body">
                    <div class="tb-card-title">{{title}}</div>
                    {{#if excerpt}}
                        <p class="tb-card-excerpt">{{excerpt}}</p>
                    {{/if}}
                    <div class="tb-card-meta">
                        <span class="tb-badge">Thông báo</span>
                        <span class="tb-date">🗓 {{date published_at format="DD/MM/YYYY"}}</span>
                        <span class="tb-readmore">Xem chi tiết →</span>
                    </div>
                </div>
            </a>
            {{else}}
            <div class="tb-empty">
                <span class="tb-empty-icon">📭</span>
                Chưa có thông báo nào.
            </div>
            {{/foreach}}
        {{/get}}
    </div>
</div>