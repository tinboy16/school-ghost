{{!< default}}
<link rel="stylesheet" href="{{asset "css/hoat-dong.css"}}">
{{#post}}
<main id="site-main" class="site-main">
<article class="article {{post_class}} {{#match @custom.post_image_style "Full"}}image-full{{else match @custom.post_image_style "=" "Small"}}image-small{{/match}}">

    <header class="article-header gh-canvas">
        <div class="article-tag post-card-tags">
            {{#primary_tag}}
                <span class="post-card-primary-tag"><a href="{{url}}">{{name}}</a></span>
            {{/primary_tag}}
            {{#if featured}}
                <span class="post-card-featured">{{> "icons/fire"}} {{t "Featured"}}</span>
            {{/if}}
        </div>

        <h1 class="article-title">{{title}}</h1>

        {{#if custom_excerpt}}
            <p class="article-excerpt">{{custom_excerpt}}</p>
        {{/if}}

        <div class="article-byline">
        <section class="article-byline-content">
            <ul class="author-list instapaper_ignore">
                {{#foreach authors}}
                <li class="author-list-item">
                    {{#if profile_image}}
                    <a href="{{url}}" class="author-avatar" aria-label="Read more of {{name}}">
                        <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}" loading="eager" />
                    </a>
                    {{else}}
                    <a href="{{url}}" class="author-avatar author-profile-image" aria-label="Read more of {{name}}">{{> "icons/avatar"}}</a>
                    {{/if}}
                </li>
                {{/foreach}}
            </ul>
            <div class="article-byline-meta">
                <h4 class="author-name">{{authors}}</h4>
                <div class="byline-meta-content">
                    <time class="byline-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                    {{#if reading_time}}
                        <span class="byline-reading-time"><span class="bull">&bull;</span> {{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
                    {{/if}}
                </div>
            </div>
        </section>
        <a href="#/share" class="gh-button gh-button-share">{{t "Share"}}</a>
        </div>

        {{#match @custom.post_image_style "!=" "Hidden"}}
        {{#if feature_image}}
            <figure class="article-image">
                <img
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w,
                            {{img_url feature_image size="xl"}} 2000w"
                    sizes="(min-width: 1400px) 1400px, 92vw"
                    src="{{img_url feature_image size="xl"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    fetchpriority="high"
                    loading="eager"
                />
                {{#if feature_image_caption}}
                    <figcaption>{{feature_image_caption}}</figcaption>
                {{/if}}
            </figure>
        {{/if}}
        {{/match}}
    </header>

    <section class="gh-content gh-canvas">
        {{content}}
    </section>

    {{!-- ========== REACTIONS ========== --}}
    <section class="post-reactions gh-canvas" 
             id="post-reactions" 
             data-postid="{{id}}" 
             data-has-hoatdong="{{#has tag="hoat-dong, Hoạt động"}}true{{/has}}">
        <div class="post-reactions-inner">
            <div class="reactions-row">
                <div class="post-reactions-group">
                    {{#has tag="hoat-dong, Hoạt động"}}
                        <button class="hd-react-btn" data-emoji="❤️" data-postid="{{id}}" title="Yêu thích">
                            <span class="hd-emoji">❤️</span>
                            <span class="hd-count" id="count-{{id}}-heart">0</span>
                        </button>
                        <button class="hd-react-btn" data-emoji="👍" data-postid="{{id}}" title="Thích">
                            <span class="hd-emoji">👍</span>
                            <span class="hd-count" id="count-{{id}}-thumbs">0</span>
                        </button>
                        <button class="hd-react-btn" data-emoji="🎉" data-postid="{{id}}" title="Tuyệt vời">
                            <span class="hd-emoji">🎉</span>
                            <span class="hd-count" id="count-{{id}}-party">0</span>
                        </button>
                        <button class="hd-react-btn" data-emoji="😮" data-postid="{{id}}" title="Wow">
                            <span class="hd-emoji">😮</span>
                            <span class="hd-count" id="count-{{id}}-wow">0</span>
                        </button>
                    {{else}}
                        {{!-- Bài viết khác: yêu cầu đăng nhập --}}
                        <button class="hd-react-btn{{#unless @member}} react-disabled{{/unless}}" data-emoji="❤️" data-postid="{{id}}" title="Yêu thích" {{#unless @member}}data-login-required="true"{{/unless}}>
                            <span class="hd-emoji">❤️</span>
                            <span class="hd-count" id="count-{{id}}-heart">0</span>
                        </button>
                        <button class="hd-react-btn{{#unless @member}} react-disabled{{/unless}}" data-emoji="👍" data-postid="{{id}}" title="Thích" {{#unless @member}}data-login-required="true"{{/unless}}>
                            <span class="hd-emoji">👍</span>
                            <span class="hd-count" id="count-{{id}}-thumbs">0</span>
                        </button>
                        <button class="hd-react-btn{{#unless @member}} react-disabled{{/unless}}" data-emoji="🎉" data-postid="{{id}}" title="Tuyệt vời" {{#unless @member}}data-login-required="true"{{/unless}}>
                            <span class="hd-emoji">🎉</span>
                            <span class="hd-count" id="count-{{id}}-party">0</span>
                        </button>
                        <button class="hd-react-btn{{#unless @member}} react-disabled{{/unless}}" data-emoji="😮" data-postid="{{id}}" title="Wow" {{#unless @member}}data-login-required="true"{{/unless}}>
                            <span class="hd-emoji">😮</span>
                            <span class="hd-count" id="count-{{id}}-wow">0</span>
                        </button>
                    {{/has}}
                </div>
            </div>
        </div>
    </section>
    {{!-- ========== END REACTIONS ========== --}}

    {{#if comments}}
        <section class="article-comments gh-canvas">
            {{comments}}
        </section>
    {{/if}}

</article>
</main>

{{#if @site.members_enabled}}
{{#unless @member}}
{{#unless @site.comments_enabled}}
{{#if access}}
    <section class="footer-cta outer">
        <div class="inner">
            {{#if @custom.email_signup_text}}<h2 class="footer-cta-title">{{@custom.email_signup_text}}</h2>{{/if}}
            <a class="footer-cta-button" href="#/portal" data-portal>
                <div class="footer-cta-input">{{t "Enter your email"}}</div>
                <span>{{t "Subscribe"}}</span>
            </a>
        </div>
    </section>
{{/if}}
{{/unless}}
{{/unless}}
{{/if}}

{{#if @custom.show_recent_posts_footer}}
    {{#get "posts" filter="id:-{{id}}" limit="3" as |more_posts|}}
        {{#if more_posts}}
            <aside class="read-more-wrap outer">
                <div class="read-more inner">
                    {{#foreach more_posts}}
                        {{> "post-card"}}
                    {{/foreach}}
                </div>
            </aside>
        {{/if}}
    {{/get}}
{{/if}}

{{/post}}

