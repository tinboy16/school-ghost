<!DOCTYPE html>
<html lang="{{@site.locale}}"{{#match @custom.color_scheme "Dark"}} class="dark-mode"{{else match @custom.color_scheme "Auto"}} class="auto-color"{{/match}}>
<head>
    <style> 
.ticker-wrap {
    background: linear-gradient(90deg, #1e3c72, #2a5298);
    color: #fff;
    padding: 7px 0;
    overflow: hidden;
    border-bottom: 2px solid rgba(255,255,255,0.12);
    position: relative;
    z-index: 999;
}

.ticker-inner {
    display: flex;
    align-items: center;
    padding: 0 16px;
}

.ticker-label {
    background: #e53e3e;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 3px;
    margin-right: 16px;
    letter-spacing: 0.5px;
    white-space: nowrap;
    flex-shrink: 0;
}

.ticker-overflow {
    overflow: hidden;
    flex: 1;
}

/* ⚠️ FIX quan trọng: dùng flex + repeat để loop mượt */
.ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 25s linear infinite;
    will-change: transform;
}

.ticker-track span,
.ticker-track a {
    display: inline-flex;
    align-items: center;
    padding: 0 40px;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
}

.ticker-track a:hover {
    color: #ffd700;
    text-decoration: underline;
}

/* dấu phân cách */
.ticker-track span::after,
.ticker-track a::after {
    content: '❖';
    margin-left: 40px;
    opacity: 0.35;
    font-size: 10px;
}

/* ⚠️ FIX animation: cần content double để loop không bị hở */
@keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

.ticker-wrap:hover .ticker-track {
    animation-play-state: paused;
}

.site-footer {
    position: relative;
    margin: max(12vmin, 64px) 0 0 0;
    padding-top: 20px;
    padding-bottom: 40px;
    color: #fff;
    background: color-mod(var(--color-darkgrey) l(-5%));
}
/* Social links */
.site-footer-social-links {
    display: flex;
    gap: 20px;
    padding-top: 5px;
}
</style>
    {{!-- Basic meta - advanced meta is output with {ghost_head} below --}}
    <title>{{meta_title}}</title>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {{!-- Preload critical resources to reduce render-blocking --}}
    <link rel="preload" as="style" href="{{asset "built/screen.css"}}" />
    <link rel="preload" as="script" href="{{asset "built/casper.js"}}" />

    {{!-- Theme assets - use the {asset} helper to reference styles & scripts,
    this will take care of caching and cache-busting automatically --}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}" />

    {{!-- This tag outputs all your advanced SEO meta, structured data, and other important settings,
    it should always be the last tag before the closing head tag --}}
    {{ghost_head}}

    {{!-- Member data for reactions - lấy UUID từ Ghost Members --}}
    <script id="member-data" type="application/json">
{{#if @member}}
{"id":"{{@member.uuid}}"}
{{else}}
{"id":null}
{{/if}}
</script>
<script>
    (function() {
        const el = document.getElementById('member-data');
        if (el) {
            try {
                const data = JSON.parse(el.textContent);
                console.log('[Member] Data from Ghost:', data);
                if (data.id) {
                    console.log('[Member] ✅ Member UUID:', data.id);
                } else {
                    console.warn('[Member] ❌ Không có member.uuid (chưa đăng nhập hoặc không có membership)');
                }
            } catch (e) {
                console.error('[Member] Lỗi parse JSON:', e);
            }
        } else {
            console.warn('[Member] Không tìm thấy #member-data');
        }
    })();
</script>

</head>
    <!-- TICKER / CHỮ CHẠY -->
