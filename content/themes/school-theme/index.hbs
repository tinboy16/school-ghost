{{!< default}}

<style>
.outer { padding: 0 20px; }
.inner { max-width: 1100px; margin: 0 auto; }

/* ===== HERO SLIDESHOW ===== */
.hero2 {
    position: relative;
    color: white;
    padding: 90px 20px;
    text-align: center;
    overflow: hidden;
    min-height: 340px;
}

.hero2-slides {
    position: absolute;
    inset: 0;
    z-index: 0;
}

.hero2-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
}

.hero2-slide.active {
    opacity: 1;
}

.hero2-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30,60,114,0.75), rgba(42,82,152,0.7));
    z-index: 1;
}

.hero2-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
}

.hero2 h1 {
    font-size: 40px;
    margin-bottom: 10px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
}

.hero2 p {
    opacity: 0.95;
    font-size: 18px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.hero2-dots {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 8px;
}

.hero2-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s;
}

.hero2-dot.active {
    background: #fff;
    transform: scale(1.2);
}

/* ===== INFO CARDS ===== */
/* ===== INFO CARDS ===== */
.grid3-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
}

.card {
    background: #fff;
    padding: 24px 20px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    text-align: center;
    transition: transform 0.2s;
    min-width: 0;
    overflow: hidden; /* ngăn nội dung tràn ra ngoài */
    word-break: break-word; /* cho phép xuống dòng */
}

.card:hover {
    transform: translateY(-6px);
}

.card h3 {
    font-size: 16px;
    margin: 0 0 10px;
    color: #1a202c;
    white-space: normal; /* ← BỎ nowrap, cho phép xuống dòng */
    word-break: break-word;
}

.card p {
    font-size: 14px;
    color: #4a5568;
    line-height: 1.6;
    margin: 0;
    word-break: break-word;
}

/* ===== NEWS ===== */
.news h2 {
    margin-top: 60px;
    margin-bottom: 24px;
    font-size: 24px;
    color: #1a202c;
    display: flex;
    align-items: center;
    gap: 8px;
}

.news h2::after {
    content: '';
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, #2a5298, transparent);
    margin-left: 12px;
    border-radius: 2px;
}

.post-feed {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

/* ===== GLOBAL ===== */
body {
    font-family: system-ui, Arial;
    background: #f7fafc;
    color: #1a202c;
}

h1, h2, h3 {
    font-weight: 700;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 600px) {
    .grid3-inner {
        grid-template-columns: 1fr;
    }

    .post-feed {
        grid-template-columns: 1fr;
    }

    .hero2 h1 { font-size: 26px; }
    .hero2 p  { font-size: 15px; }
}

@media (min-width: 601px) and (max-width: 900px) {
    .grid3-inner {
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .card {
        padding: 18px 12px;
    }

    .card h3 {
        font-size: 14px;
        white-space: normal;
    }

    .card p {
        font-size: 12px;
    }

    .post-feed {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 901px) and (max-width: 1100px) {
    .post-feed {
        grid-template-columns: repeat(2, 1fr);
    }
}
</style>


<!-- HERO -->
<header class="hero2">
    <div class="hero2-slides">
        <!-- Thay các URL ảnh bên dưới bằng ảnh thật của trường -->
        <div class="hero2-slide active"
             style="background-image: url('https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=1400')"></div>
        <div class="hero2-slide"
             style="background-image: url('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1400')"></div>
        <div class="hero2-slide"
             style="background-image: url('https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=1400')"></div>
        <div class="hero2-slide"
             style="background-image: url('https://images.unsplash.com/photo-1546410531-bb4caa6b424d?w=1400')"></div>
    </div>

    <div class="hero2-overlay"></div>

    <div class="hero2-inner">
        {{#if @site.logo}}
            <img src="{{@site.logo}}" style="width:80px;margin-bottom:10px;">
        {{/if}}

        <h1>{{@site.title}}</h1>

        <p>
            {{#if @site.description}}
                {{@site.description}}
            {{else}}
                Website chính thức Trường Tiểu học Lộc Châu 1
            {{/if}}
        </p>
    </div>

    <div class="hero2-dots" id="heroDots"></div>
</header>


<!-- INFO CARDS -->
<section class="outer">
    <div class="inner grid3-inner">
<a href="/thong-bao/" class="card-link">
    <div class="card">
        <h3>📢 Thông báo</h3>
        <p>Cập nhật lịch học, nghỉ lễ, thông báo mới nhất</p>
    </div>
</a>
<a href="/hoat-dong/" class="card-link">
    <div class="card">
        <h3>🎓 Hoạt động</h3>
        <p>Hình ảnh & hoạt động ngoại khóa học sinh</p>
    </div>
</a>
        <div class="card">
            <h3>📚 Tuyển sinh</h3>
            <p>Thông tin tuyển sinh năm học mới</p>
        </div>
    </div>
</section>


<!-- NEWS -->
<section class="news outer">
    <div class="inner">
        <h2>📰 Tin mới nhất</h2>
        <div class="post-feed">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>
    </div>
</section>


<script>
(function () {
    const slides = document.querySelectorAll('.hero2-slide');
    const dotsWrap = document.getElementById('heroDots');
    let current = 0;
    let timer;

    slides.forEach(function (_, i) {
        const dot = document.createElement('button');
        dot.className = 'hero2-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
        dot.addEventListener('click', function () { goTo(i); resetTimer(); });
        dotsWrap.appendChild(dot);
    });

    function goTo(n) {
        slides[current].classList.remove('active');
        dotsWrap.children[current].classList.remove('active');
        current = (n + slides.length) % slides.length;
        slides[current].classList.add('active');
        dotsWrap.children[current].classList.add('active');
    }

    function next() { goTo(current + 1); }

    function resetTimer() {
        clearInterval(timer);
        timer = setInterval(next, 3000);
    }

    resetTimer();
})();
</script>