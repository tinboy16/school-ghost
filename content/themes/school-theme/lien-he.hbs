    <div class="lh-layout">

        <!-- ===== CỘT TRÁI: THÔNG TIN ===== -->
        <div class="lh-info-block">
            <div class="lh-info-card">
                <div class="lh-info-icon">🏫</div>
                <div class="lh-info-body">
                    <div class="lh-info-label">Tên trường</div>
                    <div class="lh-info-value">Trường Tiểu học Lộc Châu 1</div>
                </div>
            </div>

            <div class="lh-info-card">
                <div class="lh-info-icon">📍</div>
                <div class="lh-info-body">
                    <div class="lh-info-label">Địa chỉ</div>
                    <div class="lh-info-value">
                        01 Đường Đinh Công Tráng,<br>
                        3 Bảo Lộc, Lâm Đồng, Việt Nam
                    </div>
                </div>
            </div>

            <div class="lh-info-card">
                <div class="lh-info-icon">📞</div>
                <div class="lh-info-body">
                    <div class="lh-info-label">Điện thoại</div>
                    <div class="lh-info-value">
                        <a href="tel:0263 3862 680">(0263) 3862 680</a>
                    </div>
                </div>
            </div>

            <div class="lh-info-card">
                <div class="lh-info-icon">✉️</div>
                <div class="lh-info-body">
                    <div class="lh-info-label">Email</div>
                    <div class="lh-info-value">
                        <a href="mailto:lienhe@thlochau1.edu.vn">lienhe@thlochau1.edu.vn</a>
                    </div>
                </div>
            </div>

            <!-- Giờ tiếp đón -->
            <div class="lh-hours-card">
                <div class="lh-hours-title">🕐 Giờ tiếp đón phụ huynh</div>
                <div class="lh-hours-row">
                    <span>Thứ Hai – Thứ Sáu</span>
