{{!< default}}
<style>
/* ===== TRANG LIÊN HỆ ===== */
.lh-page {
    max-width: 900px;
    margin: 48px auto;
    padding: 0 24px;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}

.lh-page-title {
    font-size: 28px;
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.lh-page-title::after {
    content: '';
    flex: 1;
    height: 3px;
    background: linear-gradient(90deg, #2a5298, transparent);
    border-radius: 2px;
    margin-left: 12px;
}

.lh-subtitle {
    color: #718096;
    font-size: 14px;
    margin-bottom: 36px;
}

/* ===== LAYOUT ===== */
.lh-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: start;
}

/* ===== THÔNG TIN LIÊN HỆ ===== */
.lh-info-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.lh-info-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    padding: 20px 22px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    border-left: 4px solid #2a5298;
    transition: transform 0.18s, box-shadow 0.18s;
}

.lh-info-card:hover {
    transform: translateX(4px);
    box-shadow: 0 6px 24px rgba(42,82,152,0.13);
}

.lh-info-icon {
    font-size: 26px;
    flex-shrink: 0;
    margin-top: 2px;
}

.lh-info-body {}

.lh-info-label {
    font-size: 11px;
    font-weight: 700;
    color: #2a5298;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 4px;
}

.lh-info-value {
    font-size: 14.5px;
    color: #2d3748;
    line-height: 1.6;
    font-weight: 500;
}

.lh-info-value a {
    color: #2a5298;
    text-decoration: none;
}

.lh-info-value a:hover {
    text-decoration: underline;
}

/* ===== GIỜ TIẾP ĐÓN ===== */
.lh-hours-card {
    background: #ebf4ff;
    border-radius: 14px;
    padding: 20px 22px;
    border-left: 4px solid #63b3ed;
}

.lh-hours-title {
    font-size: 13px;
    font-weight: 700;
    color: #2a5298;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.lh-hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 13.5px;
    color: #4a5568;
    padding: 5px 0;
    border-bottom: 1px dashed #bee3f8;
}

.lh-hours-row:last-child {
    border-bottom: none;
}

.lh-hours-row strong {
    color: #2d3748;
    font-weight: 600;
}

/* ===== FORM LIÊN HỆ ===== */
.lh-form-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    padding: 28px 28px;
}

.lh-form-heading {
    font-size: 17px;
    font-weight: 700;
    color: #1a202c;
    margin-bottom: 6px;
}

.lh-form-desc {
    font-size: 13px;
    color: #718096;
    margin-bottom: 22px;
    line-height: 1.5;
}

.lh-form-group {
    margin-bottom: 16px;
}

.lh-form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #4a5568;
    margin-bottom: 6px;
}

.lh-form-group label span.req {
    color: #e53e3e;
    margin-left: 3px;
}

.lh-form-group input,
.lh-form-group select,
.lh-form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    font-size: 14px;
    color: #2d3748;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #f8fafc;
    box-sizing: border-box;
}

.lh-form-group input:focus,
.lh-form-group select:focus,
.lh-form-group textarea:focus {
    outline: none;
    border-color: #2a5298;
    box-shadow: 0 0 0 3px rgba(42,82,152,0.1);
    background: #fff;
}

.lh-form-group textarea {
    resize: vertical;
    min-height: 110px;
}

.lh-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.lh-form-btn {
    width: 100%;
    background: #2a5298;
    color: #fff;
    border: none;
    border-radius: 9px;
    padding: 13px 20px;
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4px;
}

.lh-form-btn:hover {
    background: #1e3a7a;
    transform: translateY(-1px);
}

.lh-form-btn:active {
    transform: translateY(0);
}

/* ===== THÀNH CÔNG / LỖI ===== */
.lh-msg {
    display: none;
    border-radius: 10px;
    padding: 14px 18px;
    font-size: 14px;
    font-weight: 600;
    margin-top: 14px;
    text-align: center;
}

.lh-msg.success {
    background: #f0fff4;
    color: #276749;
    border: 1.5px solid #9ae6b4;
}

.lh-msg.error {
    background: #fff5f5;
    color: #c53030;
    border: 1.5px solid #feb2b2;
}

/* ===== BẢN ĐỒ ===== */
.lh-map-section {
    margin-top: 28px;
}

.lh-map-label {
    font-size: 14px;
    font-weight: 700;
    color: #4a5568;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
}

.lh-map-frame {
    width: 100%;
    height: 240px;
    border-radius: 14px;
    border: none;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    display: block;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 700px) {
    .lh-layout {
        grid-template-columns: 1fr;
    }

    .lh-form-row {
        grid-template-columns: 1fr;
    }

    .lh-form-card {
        padding: 20px 18px;
    }
}
</style>
