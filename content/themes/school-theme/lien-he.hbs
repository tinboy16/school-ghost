                </div>
                <div class="lh-msg" id="lh-error-msg" style="display: none; color: red; margin-top: 10px;">
                    ❌ Vui lòng điền đầy đủ các trường bắt buộc (có dấu *).
                </div>
            </form>
        </div>

    </div>
</div>

<script>
(function () {
    // URL PocketBase
    const API_URL = "https://adminct.tinnguyen.xyz/api/collections/contacts/records";

    const form       = document.getElementById("lh-contact-form");
    const btnSubmit  = document.getElementById("lh-submit-btn");
    const msgSuccess = document.getElementById("lh-success-msg");
    const msgError   = document.getElementById("lh-error-msg");

    function hideMessages() {
        msgSuccess.style.display = "none";
        msgError.style.display = "none";
    }

    form.addEventListener("submit", async function (e) {
        e.preventDefault();
        hideMessages();

        if (!form.checkValidity()) {
            msgError.textContent = "❌ Vui lòng điền đầy đủ các trường bắt buộc.";
            msgError.style.display = "block";
            return;
        }

        btnSubmit.disabled = true;
        btnSubmit.innerHTML = "⌛ Đang gửi...";

        const data = {
            ho_ten: form.ho_ten.value,
            vai_tro: form.vai_tro.value,
            email: form.email.value,
            so_dien_thoai: form.so_dien_thoai.value,
            chu_de: form.chu_de.value,
            noi_dung: form.noi_dung.value
        };

        try {
            const response = await fetch(API_URL, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                const err = await response.text();
                throw new Error(err);
            }

            msgSuccess.style.display = "block";
            form.reset();

        } catch (err) {
            console.error(err);

            msgError.textContent =
                "❌ Không gửi được thông tin. Vui lòng thử lại sau.";

            msgError.style.display = "block";
        }

        btnSubmit.disabled = false;
        btnSubmit.innerHTML = '<span>📨</span> Gửi tin nhắn';
    });
})();
</script>
