                </div>
                <div class="lh-hours-row">
                    <span>Chủ Nhật & Lễ</span>
                    <strong>Nghỉ</strong>
                </div>
            </div>

            <!-- Bản đồ -->
            <div class="lh-map-section">
                <div class="lh-map-label">🗺️ Vị trí trường</div>
                <iframe
                    class="lh-map-frame"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3909.3257301495437!2d107.77270237535961!3d11.528475388669731!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3173f71232be74bb%3A0xcd77a156e006ab1c!2zVHLGsOG7nW5nIFRp4buDdSBo4buNYyBM4buZYyBDaMOidSAxLCBM4buZYyBDaMOidSwgQuG6o28gTOG7mWMsIEzDom0gxJDhu5NuZw!5e0!3m2!1svi!2s!4v1782471597909!5m2!1svi!2s"
