                    <select id="lh-chu-de" name="chu_de" required>
                        <option value="">-- Chọn chủ đề --</option>
                        <option value="tuyen-sinh">Tuyển sinh & Nhập học</option>
                        <option value="hoc-phi">Học phí & Hỗ trợ</option>
                        <option value="chuong-trinh">Chương trình học</option>
                        <option value="hoat-dong">Hoạt động ngoại khóa</option>
                        <option value="co-so-vat-chat">Cơ sở vật chất</option>
                        <option value="phan-hoi">Phản hồi & Góp ý</option>
                        <option value="khac">Khác</option>
                    </select>
                </div>

                <div class="lh-form-group">
                    <label for="lh-noi-dung">Nội dung <span class="req">*</span></label>
