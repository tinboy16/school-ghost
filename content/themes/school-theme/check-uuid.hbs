{{! 
  Trang kiểm tra UUID thành viên
  Đường dẫn: /check-uuid
  Chỉ dành cho thành viên đã đăng nhập
}}

{{! Layout chính }}
{{!< default}}

{{#contentFor "title"}}Kiểm tra UUID thành viên{{/contentFor}}

<main class="check-uuid-page">
  <div class="container">
    <h1>🔍 Kiểm tra UUID thành viên</h1>
    
    {{#if @member}}
      {{!-- Thành viên đã đăng nhập --}}
      <div class="member-card">
        <div class="member-info">
          <h2>Thông tin thành viên</h2>
          
          <div class="info-item">
            <label>👤 Họ tên:</label>
            <span class="value">{{@member.name}}</span>
          </div>
          
          <div class="info-item">
            <label>📧 Email:</label>
            <span class="value">{{@member.email}}</span>
          </div>
          
          <div class="info-item highlight">
            <label>🔑 UUID:</label>
            <span class="value uuid-display" id="member-uuid">{{@member.uuid}}</span>
            <button class="copy-btn" onclick="copyUUID()">📋 Copy</button>
          </div>
          
          <div class="info-item">
            <label>💳 Trạng thái:</label>
            <span class="value">
              {{#if @member.paid}}
                <span class="badge paid">Thành viên trả phí ✅</span>
              {{else}}
                <span class="badge free">Thành viên miễn phí</span>
              {{/if}}
            </span>
          </div>
        </div>
        
        {{!-- Hiển thị thông tin đăng ký nếu có --}}
        {{#if @member.subscriptions}}
          <div class="subscriptions">
            <h3>📋 Đăng ký của bạn</h3>
            {{#foreach @member.subscriptions}}
              <div class="subscription-item">
                <p>
                  <strong>Gói:</strong> {{plan.nickname}} 
                  (<span class="status-{{status}}">{{status}}</span>)
                </p>
                <p><strong>Giá:</strong> {{price plan}}/{{plan.interval}}</p>
                <p><strong>Hạn đến:</strong> {{date current_period_end format="DD/MM/YYYY"}}</p>
                {{#if default_payment_card_last4}}
                  <p><strong>Thẻ:</strong> **** {{default_payment_card_last4}}</p>
                {{/if}}
              </div>
            {{/foreach}}
          </div>
        {{/if}}
        
        {{!-- Các công cụ hữu ích --}}
        <div class="tools">
          <h3>🛠️ Công cụ</h3>
          <div class="tool-buttons">
            <button onclick="testUUID('{{@member.uuid}}')">Kiểm tra UUID</button>
            <button onclick="showFullMember()">Xem toàn bộ @member</button>
          </div>
          <div id="debug-output" style="display:none; margin-top: 15px; background: #f5f5f5; padding: 15px; border-radius: 5px; overflow: auto; max-height: 300px;">
            <pre id="debug-content"></pre>
          </div>
        </div>
      </div>
      
    {{else}}
      {{!-- Chưa đăng nhập --}}
      <div class="login-required">
        <h2>🔒 Yêu cầu đăng nhập</h2>
        <p>Vui lòng đăng nhập để xem UUID của bạn.</p>
        <a href="#/portal/signin" class="btn btn-primary">Đăng nhập ngay</a>
      </div>
    {{/if}}
  </div>
</main>

{{#contentFor "styles"}}
