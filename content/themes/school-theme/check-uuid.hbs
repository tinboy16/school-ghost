{{#contentFor "scripts"}}
<script>
  // Copy UUID
  function copyUUID() {
    const uuidElement = document.getElementById('member-uuid');
    const uuid = uuidElement.textContent.trim();
    
    navigator.clipboard.writeText(uuid).then(() => {
      const btn = document.querySelector('.copy-btn');
      btn.textContent = '✅ Copied!';
      setTimeout(() => {
        btn.textContent = '📋 Copy';
      }, 2000);
    }).catch(err => {
      // Fallback method
      const textArea = document.createElement('textarea');
      textArea.value = uuid;
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      
      const btn = document.querySelector('.copy-btn');
      btn.textContent = '✅ Copied!';
      setTimeout(() => {
        btn.textContent = '📋 Copy';
      }, 2000);
    });
  }
  
  // Test UUID
  function testUUID(uuid) {
    const output = document.getElementById('debug-output');
    const content = document.getElementById('debug-content');
    
    const info = {
      'UUID': uuid,
      'Length': uuid.length,
      'Format': 'UUID v4',
      'Is Valid': /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(uuid) ? '✅ Yes' : '❌ No'
    };
    
    content.textContent = JSON.stringify(info, null, 2);
    output.style.display = 'block';
  }
  
  // Show full @member object
  function showFullMember() {
    const output = document.getElementById('debug-output');
    const content = document.getElementById('debug-content');
    
    // Chỉ hoạt động nếu có data-member
    const memberData = {
      name: '{{@member.name}}',
      email: '{{@member.email}}',
      uuid: '{{@member.uuid}}',
      paid: {{#if @member.paid}}true{{else}}false{{/if}},
      subscriptions: [
        {{#foreach @member.subscriptions}}
        {
          plan: '{{plan.nickname}}',
          status: '{{status}}',
          amount: '{{price plan}}',
          interval: '{{plan.interval}}'
        }{{#unless @last}},{{/unless}}
        {{/foreach}}
      ]
    };
    
    content.textContent = JSON.stringify(memberData, null, 2);
    output.style.display = 'block';
  }
</script>
{{/contentFor}}